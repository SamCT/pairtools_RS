{
  "id": "M194",
  "name": "Cross command threaded IO",
  "status": "planned",
  "summary": "Implement threaded BGZF I/O for commands that currently reject nproc-in/out.",
  "goal": "Add HTSlib BGZF threaded input/output support for eligible downstream commands, prioritizing dedup, select, split, merge, and parse outputs where semantics are already implemented.",
