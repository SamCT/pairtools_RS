{
  "id": "M180",
  "name": "Select expression engine",
  "status": "complete",
  "summary": "Expand select beyond exact pair_type equality.",
  "goal": "Implement a bounded pairtools-compatible select expression engine covering boolean operators, column references, string equality, numeric comparisons, and parentheses on committed fixtures.",
