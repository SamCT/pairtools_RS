{
  "id": "M200",
  "name": "Filterbycov core",
  "status": "planned",
  "summary": "Implement scoped filterbycov command.",
  "goal": "Implement `pairs-rs filterbycov` for pairtools-compatible high-coverage filtering on sorted pairs input with explicit output streams and stats.",
  "explicit_non_goals": [
    "Do not broaden unrelated commands.",
    "Do not claim full pairtools parity beyond committed oracle fixtures.",
    "Do not run benchmarks or claim speedup.",
    "Pairtools may be used only as a test oracle."
  ],
  "allowed_paths": [
    "src/cli.rs",
    "src/main.rs",
    "src/filterbycov.rs",
    "tests/**",
    "docs/**",
    "milestone_results/**",
    "milestones/ACTIVE_MILESTONE",
    "milestones/M200-filterbycov-core.json"
  ],
  "forbidden_paths": [
    "Cargo.toml",
    "Cargo.lock",
    "pixi.toml",
    "pixi.lock",
    "build.rs"
  ],
  "allowed_commands": [
    "scripts/cargo_guard.sh check",
    "scripts/cargo_guard.sh test"
  ],
  "forbidden_commands": [
    "cargo check",
