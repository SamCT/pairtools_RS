{
  "id": "M170",
  "name": "Flip core",
  "status": "planned",
  "summary": "Implement scoped pairtools-compatible flip behavior.",
  "goal": "Implement `pairs-rs flip` for upper-triangle normalization on pairs/pairsam input with header preservation, chrom order support, and loud failures for unsupported options.",
  "explicit_non_goals": [
    "Do not broaden unrelated commands.",
    "Do not claim full pairtools parity beyond committed oracle fixtures.",
    "Do not run benchmarks or claim speedup.",
    "Pairtools may be used only as a test oracle.",
    "Do not change parse-time default flipping behavior in this milestone."
  ],
  "allowed_paths": [
    "src/cli.rs",
    "src/main.rs",
    "src/flip.rs",
    "tests/**",
    "docs/**",
    "milestone_results/**",
    "milestones/ACTIVE_MILESTONE",
    "milestones/M170-flip-core.json"
  ],
  "forbidden_paths": [
    "Cargo.toml",
    "Cargo.lock",
    "pixi.toml",
    "pixi.lock",
    "build.rs"
  ],
  "allowed_commands": [
    "scripts/cargo_guard.sh check",
    "scripts/cargo_guard.sh test"
  ],
  "forbidden_commands": [
    "cargo check",
    "cargo test",
    "cargo build",
    "pixi run cargo check",
    "pixi run cargo test",
    "pixi run cargo build"
  ],
  "allowed_pairtools_commands": [
